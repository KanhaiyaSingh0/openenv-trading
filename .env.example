# OpenEnv Hackathon - Inference Configuration
# Copy this to .env and fill in your actual values

# REQUIRED: Hugging Face API Token (for model inference)
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN="hf_your_token_here"

# OPTIONAL: LLM API Configuration (defaults provided if not set)
# API Base URL for LLM service
API_BASE_URL="https://router.huggingface.co/v1"

# Model name to use for inference
# Must be a model available via the API (7B models recommended for 8GB RAM limit)
# Examples: meta-llama/Llama-2-7b-chat-hf, Qwen/Qwen2.5-7B-Instruct
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Trading server endpoint (for development/testing only)
SERVER_URL="http://localhost:8000"
